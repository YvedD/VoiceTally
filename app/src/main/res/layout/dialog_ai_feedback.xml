<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/vt5_dark_gray">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Beoordeel de AI-prognose"
        android:textColor="@color/vt5_on_surface"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hoe accuraat waren de suggesties van vandaag?"
        android:textColor="@color/vt5_on_surface"
        android:alpha="0.8"
        android:textSize="14sp"
        android:paddingBottom="16dp" />

    <RatingBar
        android:id="@+id/rbAiAccuracy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:numStars="5"
        android:stepSize="1.0"
        android:theme="@style/Widget.AppCompat.RatingBar" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Algemene opmerkingen over de prognose"
        app:boxStrokeColor="@color/vt5_outline"
        app:hintTextColor="@color/vt5_outline">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAiFeedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="@color/vt5_on_surface" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
