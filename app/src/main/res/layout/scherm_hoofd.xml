<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/vt5_black">

    <LinearLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="45dp"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="50dp"
        android:paddingRight="20dp"
        android:paddingBottom="60dp">

    <TextView
        android:id="@+id/tvTitel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="@string/titel_hoofd"
        android:textColor="@color/vt5_on_surface"
        android:textSize="22sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInstall"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/titel_install"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerder"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/btn_verder_metadata"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnJoinAsClient"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/mc_btn_join_as_client"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAfsluiten"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_afsluiten"
        android:textSize="16sp" />

    <!-- Alarm sectie -->
    <View
        android:id="@+id/divider_alarm"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="12dp"
        android:alpha="0.3"
        android:background="@color/vt5_on_surface" />

    <TextView
        android:id="@+id/tvAlarmStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:text=""
        android:textColor="@color/vt5_on_surface"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToggleAlarm"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hoofd_alarm_toggle"
        android:textSize="14sp" />

    <!-- Telling Beheer sectie -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBewerkTellingen"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/hoofd_bewerk_tellingen"
        android:textSize="14sp" />

    <!-- Exports opkuis sectie -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpkuisExports"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/hoofd_opkuis_exports"
        android:textSize="14sp" />

    <!-- Instellingen sectie -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInstellingen"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/hoofd_instellingen"
        android:textSize="14sp" />

    <!-- Database Beheer sectie -->
    <!-- AI sectie met twee knoppen op één regel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiUpdate"
            style="@style/Widget.VT5.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/hoofd_ai_update"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiForecast3Days"
            style="@style/Widget.VT5.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/hoofd_ai_forecast_3days"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDatabaseBeheer"
        style="@style/Widget.VT5.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/hoofd_database_beheer"
        android:textSize="14sp" />

    </LinearLayout>

</ScrollView>

