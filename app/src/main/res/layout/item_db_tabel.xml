<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/vt5_black"
    app:cardCornerRadius="8dp"
    app:strokeColor="@color/vt5_on_surface"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvTabelNaam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/vt5_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecordsCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/vt5_on_surface"
            android:textSize="14sp"
            android:alpha="0.8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWissenRecords"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/db_beheer_wissen_records"
                android:textSize="12sp"
                app:strokeColor="@color/vt5_on_surface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWissenTabel"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/db_beheer_wissen_tabel"
                android:textColor="@android:color/holo_red_light"
                android:textSize="12sp"
                app:strokeColor="@android:color/holo_red_light" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
