<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
    android:paddingBottom="40dp"
    android:background="@color/vt5_black"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTerug"
            style="@style/Widget.VT5.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:text="@string/instellingen_back_arrow"
            android:textSize="18sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="@string/db_beheer_btn_soort_zoeken"
            android:textColor="@color/vt5_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToonGrafieken"
            style="@style/Widget.VT5.Button.Outlined.IconOnly"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@drawable/ic_action_sum"
            app:iconTint="@color/vt5_light_blue"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.3"
        android:background="@color/vt5_on_surface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <AutoCompleteTextView
            android:id="@+id/atvSoortZoeken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/vt5_on_surface"
            android:hint="@string/db_beheer_hint_soortnaam"
            android:textColor="@color/vt5_on_surface"
            android:textColorHint="@color/vt5_on_surface" />

        <TextView
            android:id="@+id/tvSoortInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/vt5_on_surface"
            android:textSize="14sp"
            android:textStyle="italic" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutGrafieken"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Noord (N, NW, NNW, NO, NNO)"
            android:textColor="@color/vt5_light_blue"
            android:textSize="12sp" />
        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartNoord"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oost (O, NO, NNO, OZO, ZZO)"
            android:textColor="@color/vt5_light_blue"
            android:textSize="12sp" />
        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartOost"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zuid (Z, ZZO, ZO, ZW, ZZW)"
            android:textColor="@color/vt5_light_blue"
            android:textSize="12sp" />
        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartZuid"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="West (W, WZW, ZW, NW, WNW)"
            android:textColor="@color/vt5_light_blue"
            android:textSize="12sp" />
        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartWest"
            android:layout_width="match_parent"
            android:layout_height="120dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWaarnemingen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp" />

</LinearLayout>
