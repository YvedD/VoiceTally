<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:importantForAutofill="noExcludeDescendants"
    android:orientation="vertical"
    android:padding="12dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="560dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_pairing_master_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/vt5_on_surface"
                android:paddingBottom="6dp" />

            <!-- Hotspot gegevens (voor QR) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_pairing_hotspot_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/vt5_on_surface"
                android:paddingTop="4dp"
                android:paddingBottom="2dp" />

            <AutoCompleteTextView
                android:id="@+id/etHotspotSsid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="username"
                android:hint="@string/mc_pairing_hotspot_ssid_hint"
                android:inputType="textNoSuggestions"
                android:textColor="@color/vt5_on_surface"
                android:textColorHint="#888888"
                android:background="@android:color/transparent"
                android:paddingBottom="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanWifi"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/mc_pairing_wifi_scan" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenHotspotSettings"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/mc_pairing_open_hotspot_settings" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_pairing_hotspot_wpa2_hint"
                android:textSize="12sp"
                android:textColor="@color/vt5_on_surface"
                android:alpha="0.7"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/tvWifiStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_wifi_status_unknown"
                android:textSize="12sp"
                android:textColor="@color/vt5_on_surface"
                android:alpha="0.75"
                android:paddingBottom="6dp" />

            <EditText
                android:id="@+id/etHotspotPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="password"
                android:hint="@string/mc_pairing_hotspot_pass_hint"
                android:inputType="textPassword"
                android:textColor="@color/vt5_on_surface"
                android:textColorHint="#888888"
                android:background="@android:color/transparent"
                android:paddingBottom="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateQrs"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:enabled="false"
                android:text="@string/mc_pairing_generate_qrs" />

            <!-- Wi-Fi QR (voor verbinding met hotspot) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_pairing_wifi_qr_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/vt5_on_surface"
                android:paddingTop="4dp"
                android:paddingBottom="2dp" />

            <ImageView
                android:id="@+id/ivWifiQr"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/mc_pairing_wifi_qr_label"
                android:background="#1A1A2E" />

            <TextView
                android:id="@+id/tvWifiQrInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:gravity="center_horizontal"
                android:textColor="@color/vt5_on_surface"
                android:alpha="0.7"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />

            <!-- QR-code voor snelle koppeling -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mc_pairing_qr_label"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/vt5_on_surface"
                android:paddingTop="4dp"
                android:paddingBottom="2dp" />

            <ImageView
                android:id="@+id/ivPairingQr"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/mc_pairing_qr_label"
                android:background="#1A1A2E" />

            <TextView
                android:id="@+id/tvPairingQrInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:gravity="center_horizontal"
                android:textColor="@color/vt5_on_surface"
                android:alpha="0.7"
                android:paddingTop="4dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClosePairing"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/mc_pairing_close" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
