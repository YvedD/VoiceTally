<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingTop="3dp"
    android:paddingEnd="4dp"
    android:paddingBottom="3dp">

    <!-- Tijdstip links (HH:mm:ss) -->
    <TextView
        android:id="@+id/tvBirdTime"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:ellipsize="none"
        android:maxLines="1"
        android:textColor="#88AACCEE"
        android:textSize="11sp" />

    <!-- Soortinfo: volksnaam + wetenschappelijke naam -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="3dp">

        <TextView
            android:id="@+id/tvBirdCommonName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBirdScientificName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#AAAAAA"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Confidence-percentage rechts, gekleurd op basis van waarde -->
    <TextView
        android:id="@+id/tvBirdConfidence"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:maxLines="1"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>

