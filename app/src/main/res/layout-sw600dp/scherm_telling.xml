<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="40dp"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Titel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="0dp"
        android:layout_marginRight="35dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="1dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="start|center_vertical"
            android:paddingLeft="10dp"
            android:text="@string/telling_speech_results"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnToggleAlarm"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/hoofd_alarm_enabled"
            android:src="@android:drawable/ic_lock_idle_alarm"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btnMasterClientConnection"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/mc_enable_master_mode"
            android:src="@drawable/ic_mc_wifi"
            app:tint="#808080" />

        <ImageButton
            android:id="@+id/btnShowMasterQr"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/mc_show_qr_codes"
            android:src="@drawable/ic_qr_code"
            android:visibility="gone"
            app:tint="#808080" />

        <ImageButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/instellingen_titel"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@android:color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMasterClientStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:alpha="0.9"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textColor="@color/vt5_on_surface"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- Bovenste kaart: PARTIALS / niet‑finals -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSpeechPartials"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        app:cardCornerRadius="8dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="@color/vt5_light_blue"
        app:strokeWidth="2dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewSpeechPartials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111"
            android:padding="6dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Onderste kaart: FINALS -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSpeechFinals"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        app:cardCornerRadius="8dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="@color/vt5_green"
        app:strokeWidth="2dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewSpeechFinals"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111"
            android:padding="6dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Actieknoppen -->
    <LinearLayout
        android:id="@+id/knoppenBalk1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/btnSaveClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:paddingLeft="3dp"
            android:paddingTop="3dp"
            android:paddingRight="3dp"
            android:text="@string/telling_totals" />

        <Button
            android:id="@+id/btnAddSoorten"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:paddingLeft="3dp"
            android:paddingTop="3dp"
            android:paddingRight="3dp"
            android:text="@string/telling_add" />

        <Button
            android:id="@+id/btnAfronden"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:layout_marginStart="8dp"
            android:paddingLeft="3dp"
            android:paddingTop="3dp"
            android:paddingRight="3dp"
            android:text="@string/telling_finish" />
    </LinearLayout>

    <!-- Grid met soort-tiles -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSpecies"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>