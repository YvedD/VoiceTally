<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="30dp"
    android:paddingBottom="40dp"
    android:background="@color/vt5_black"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTerug"
            style="@style/Widget.VT5.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:text="@string/instellingen_back_arrow"
            android:textSize="18sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/db_beheer_titel"
            android:textColor="@color/vt5_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.3"
        android:background="@color/vt5_on_surface" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Grafiek Sectie -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activiteit Overzicht"
                android:textColor="@color/vt5_light_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/vt5_dark_gray"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/vt5_light_blue"
                app:strokeWidth="1dp">

                <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
                    android:id="@+id/chartActivity"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="16dp"
                    app:scrollEnabled="false"
                    app:zoomEnabled="false" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Navigatie Knoppen -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTellingenLijst"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/db_beheer_btn_sessies"
                android:textSize="18sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSoortZoeken"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/db_beheer_btn_soort_zoeken"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <!-- Tabel Overzicht -->
            <LinearLayout
                android:id="@+id/containerTabellen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetDatabase"
                style="@style/Widget.VT5.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:text="Database Volledig Resetten"
                android:textColor="@color/vt5_red"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="@color/vt5_red"
                app:strokeColor="@color/vt5_red" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
