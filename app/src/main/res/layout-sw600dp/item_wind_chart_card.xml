<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/vt5_dark_gray"
    app:cardCornerRadius="12dp"
    app:strokeColor="@color/vt5_light_blue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvDirectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/popup_bg_wit"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartDirection"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:padding="6dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

