<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/vt5_dark_gray"
    app:cardCornerRadius="12dp"
    app:strokeColor="@color/vt5_light_blue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvDirectionHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/popup_bg_wit"
                android:textSize="14sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/cbShowTrek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chart_show_trek"
                android:textColor="@color/popup_bg_wit"
                android:checked="true"
                android:paddingStart="8dp"
                android:paddingEnd="0dp" />

            <CheckBox
                android:id="@+id/cbShowReturn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/chart_show_return"
                android:textColor="@color/popup_bg_wit"
                android:checked="true"
                android:paddingStart="8dp"
                android:paddingEnd="0dp" />

        </LinearLayout>

        <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
            android:id="@+id/chartDirection"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:padding="6dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

