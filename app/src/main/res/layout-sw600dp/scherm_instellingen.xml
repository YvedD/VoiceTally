<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vt5_black"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTerug"
            style="@style/Widget.VT5.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:text="@string/instellingen_back_arrow"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvTitel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/instellingen_titel"
            android:textColor="@color/vt5_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.3"
        android:background="@color/vt5_on_surface" />

    <!-- Tablet: scrollable zodat alles zichtbaar blijft -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Lettergrootte partials (compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/tvLettergroottePartialsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/instellingen_lettergrootte_partials_label"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />

                <NumberPicker
                    android:id="@+id/npLettergroottePartials"
                    android:layout_width="100dp"
                    android:layout_height="70dp"
                    android:theme="@style/Theme.VT5.NumberPicker" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="@string/instellingen_sp_eenheid"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Lettergrootte finals (compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/tvLettergrootteFinalsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/instellingen_lettergrootte_finals_label"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />

                <NumberPicker
                    android:id="@+id/npLettergrootteFinals"
                    android:layout_width="100dp"
                    android:layout_height="70dp"
                    android:theme="@style/Theme.VT5.NumberPicker" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="@string/instellingen_sp_eenheid"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Log-kleuren bij log-grootte -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/instellingen_partials_text_color_label"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spPartialsTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/instellingen_finals_text_color_label"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp"
                android:layout_marginTop="6dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spFinalsTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <!-- Lettergrootte tegels (compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <TextView
                    android:id="@+id/tvLettergrootteTegelsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/instellingen_lettergrootte_tegels_label"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />

                <NumberPicker
                    android:id="@+id/npLettergrootteTegels"
                    android:layout_width="100dp"
                    android:layout_height="70dp"
                    android:theme="@style/Theme.VT5.NumberPicker" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="@string/instellingen_sp_eenheid"
                    android:textColor="@color/vt5_on_surface"
                    android:textSize="15sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <TextView
                android:id="@+id/tvDoubleTapTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_double_tap_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoubleTap5"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_double_tap_5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoubleTap10"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_double_tap_10" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoubleTap50"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_double_tap_50" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoubleTap100"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_double_tap_100" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPendingTilesTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_pending_tiles_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPendingTilesSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_pending_tiles_subtitle"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles2"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles3"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles5"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles8"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_8" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles10"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_10" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles12"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_12" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPendingTiles15"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:checkable="true"
                    android:text="@string/instellingen_pending_tiles_15" />
            </LinearLayout>

            <!-- Favorieten limiet -->
            <TextView
                android:id="@+id/tvFavTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_fav_limit_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav15"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_15" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav20"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_20" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav25"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_25" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav30"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_30" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav35"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_35" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav40"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_40" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFav75"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_75" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavAll"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:minHeight="40dp"
                    android:checkable="true"
                    android:text="@string/instellingen_fav_all" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <TextView
                android:id="@+id/tvSilentUploadTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_silent_upload_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSilentUploadSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_silent_upload_subtitle"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilentUploadUit"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_silent_upload_off" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilentUpload5"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_silent_upload_5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilentUpload10"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_silent_upload_10" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilentUpload15"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_silent_upload_15" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilentUpload30"
                    style="@style/Widget.VT5.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:text="@string/instellingen_silent_upload_30" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <!-- Kleuren -->
            <TextView
                android:id="@+id/tvKleurTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_colors_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_bg_color_label"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spBackgroundColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingBottom="6dp"
                android:text="@string/instellingen_text_color_label"
                android:textColor="@color/vt5_on_surface"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spTextColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:alpha="0.3"
                android:background="@color/vt5_on_surface" />

            <!-- Toestemmingen (info) -->
            <TextView
                android:id="@+id/tvPermissiesTitel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/instellingen_permissions_title"
                android:textColor="@color/vt5_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:paddingBottom="6dp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbPermAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_audio_checkbox"
                android:textColor="@color/vt5_on_surface"
                android:textSize="13sp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbPermSaf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/perm_saf_checkbox"
                android:textColor="@color/vt5_on_surface"
                android:textSize="13sp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbPermLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/perm_location_checkbox"
                android:textColor="@color/vt5_on_surface"
                android:textSize="13sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

